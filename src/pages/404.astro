---
import logo from '../assets/aerl-logo.png';
import '../styles/aerl.css';
---

<!doctype html>
<html lang="en" data-theme="dark">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>Page Not Found | AERL</title>
		<meta
			name="description"
			content="The page you requested could not be found on the Applied Engineering Research Lab website."
		/>
	</head>
	<body class="aerl-404-page">
		<main class="aerl-404-shell">
			<div class="aerl-404-card">
				<img class="aerl-404-logo" src={logo.src} alt="AERL logo" />
				<p class="aerl-section-label">404</p>
				<h1>Page not found.</h1>
				<p>
					The page you requested does not exist or has moved. Start from the homepage or go
					directly to the Flight Control System project hub.
				</p>
				<div class="aerl-home-cta-links">
					<a href="/">Back to Home</a>
					<a href="/projects/fcs/">Open FCS Project</a>
				</div>
			</div>
		</main>
	</body>
</html>
